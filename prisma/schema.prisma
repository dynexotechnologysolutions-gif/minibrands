datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String       @id
  name          String
  email         String
  emailVerified Boolean      @default(false)
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  sessions      Session[]
  accounts      Account[]
  userProfile   UserProfile?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model UserProfile {
  id             String          @id @default(uuid())
  userId         String          @unique
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role            @default(BUYER)
  createdAt      DateTime        @default(now())
  seller         Seller?
  addresses      Address[]
  orders         Order[]
  reviewsGiven   Review[]        @relation("BuyerReviews")
  returnRequests ReturnRequest[]
  returnCount    Int             @default(0)
  refundCount    Int             @default(0)
  disputeCount   Int             @default(0)
  abuseScore     Float           @default(0.0)

  @@index([role])
  @@map("user_profile")
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

model Seller {
  id                    String              @id @default(uuid())
  userProfileId         String              @unique
  userProfile           UserProfile         @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  businessName          String
  storeName             String              @default("")
  storeLogo             String?
  storeBanner           String?
  storeDescription      String?
  category              String
  city                  String
  razorpayFundAccountId String?
  verification          SellerVerification?
  products              Product[]
  orders                Order[]
  reviews               Review[]
  createdAt             DateTime            @default(now())

  @@index([city])
  @@index([category])
  @@map("seller")
}

model SellerVerification {
  id                String    @id @default(uuid())
  sellerId          String    @unique
  seller            Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  kycStatus         String    @default("pending")
  signzyReferenceId String?
  faceMatchScore    Float?
  bankAccountLast4  String?
  bankVerified      Boolean   @default(false)
  trustScore        Float     @default(0)
  rejectionReason   String?
  verifiedAt        DateTime?
  createdAt         DateTime  @default(now())

  @@index([kycStatus])
  @@map("seller_verification")
}

model Product {
  id               String           @id @default(uuid())
  sellerId         String
  seller           Seller           @relation(fields: [sellerId], references: [id])
  name             String
  shortDescription String
  fullDescription  String
  category         String
  subcategory      String?
  tags             String[]
  price            Int              // paise (smallest INR unit)
  isPublished      Boolean          @default(false)
  publishedAt      DateTime?
  isDeleted        Boolean          @default(false)
  aiGenerated      Boolean          @default(false)
  averageRating    Float            @default(0)
  reviewCount      Int              @default(0)
  images           ProductImage[]
  variants         ProductVariant[]
  orderItems       OrderItem[]
  reviews          Review[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([sellerId])
  @@index([category])
  @@index([isPublished])
  @@index([isDeleted])
  @@index([isPublished, category])
  @@map("product")
}

model ProductImage {
  id                 String   @id @default(uuid())
  productId          String
  product            Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  cloudinaryPublicId String
  url                String
  sortOrder          Int      @default(0)

  @@index([productId])
  @@map("product_image")
}

model ProductVariant {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  size        String
  stockCount  Int      @default(0)
  orderItems  OrderItem[]

  @@index([productId])
  @@map("product_variant")
}

model Address {
  id            String      @id @default(uuid())
  userProfileId String
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id])
  fullName      String
  phone         String
  line1         String
  line2         String?
  city          String
  pincode       String
  isDefault     Boolean     @default(false)
  isDeleted     Boolean     @default(false)
  latitude      Float?
  longitude     Float?
  createdAt     DateTime    @default(now())
  orders        Order[]

  @@index([userProfileId])
  @@index([isDeleted])
  @@map("address")
}

model Order {
  id                  String      @id @default(uuid())
  buyerId             String
  buyer               UserProfile @relation(fields: [buyerId], references: [id])
  sellerId            String
  seller              Seller      @relation(fields: [sellerId], references: [id])
  addressId           String
  address             Address     @relation(fields: [addressId], references: [id])
  status              OrderStatus @default(created)
  subtotal            Int         @default(0) // paise
  shipping            Int         @default(0) // paise
  tax                 Int         @default(0) // paise
  totalAmount         Int         // paise
  commissionAmount    Int         // paise, calculated server-side
  paymentStatus       String      @default("pending")
  orderStatus         String      @default("created")
  razorpayOrderId     String?     @unique
  razorpayPaymentId   String?     @unique
  escrowReleaseAt     DateTime?   // set when buyer confirms delivery
  icarryOrderId       String?
  icarryAwbNumber     String?
  icarryLabelUrl      String?
  trackingUrl         String?
  razorpayPayoutId    String?     @unique
  items               OrderItem[]
  review              Review?
  returnRequest       ReturnRequest?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([razorpayOrderId])
  @@index([status, escrowReleaseAt])
  @@map("order")
}

enum OrderStatus {
  created
  paid
  confirmed
  shipped
  delivered
  completed
  cancelled
  disputed
}

model OrderItem {
  id          String         @id @default(uuid())
  orderId     String
  order       Order          @relation(fields: [orderId], references: [id])
  productId   String
  product     Product        @relation(fields: [productId], references: [id])
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id])
  quantity    Int
  unitPrice   Int            // paise
  returnItems ReturnItem[]

  @@index([orderId])
  @@map("order_item")
}

model Payment {
  id                String   @id @default(uuid())
  razorpayPaymentId String   @unique
  razorpayOrderId   String
  amount            Int      // paise
  paymentMethod     String
  status            String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("payment")
}

model Review {
  id        String      @id @default(uuid())
  orderId   String      @unique
  order     Order       @relation(fields: [orderId], references: [id])
  buyerId   String
  buyer     UserProfile @relation("BuyerReviews", fields: [buyerId], references: [id])
  sellerId  String
  seller    Seller      @relation(fields: [sellerId], references: [id])
  productId String
  product   Product     @relation(fields: [productId], references: [id])
  rating    Int
  comment   String?
  photoUrls String[]
  isVisible Boolean     @default(true)
  createdAt DateTime    @default(now())

  @@index([sellerId])
  @@index([productId])
  @@index([buyerId])
  @@map("review")
}

model NotificationLog {
  id           String   @id @default(uuid())
  to           String
  template     String
  params       String[]
  status       String   // "sent", "failed", "mocked"
  errorMessage String?
  createdAt    DateTime @default(now())

  @@map("notification_log")
}

enum ReturnRequestStatus {
  RETURN_REQUESTED
  SELLER_REVIEW
  APPROVED
  PICKUP_SCHEDULED
  PICKED_UP
  IN_TRANSIT
  DELIVERED_TO_SELLER
  UNDER_INSPECTION
  REFUND_APPROVED
  REFUND_PROCESSING
  REFUNDED
  RETURN_COMPLETED
  REJECTED
  CANCELLED
  DISPUTED
  ESCALATED
}

enum InspectionResult {
  PENDING
  PASSED
  FAILED
  PARTIAL
}

enum RefundMethod {
  ORIGINAL_PAYMENT
  STORE_CREDIT
  MANUAL_BANK_TRANSFER
}

enum ReturnReason {
  DAMAGED
  WRONG_PRODUCT
  SIZE_ISSUE
  QUALITY_ISSUE
  NOT_AS_DESCRIBED
  CHANGED_MIND
  OTHER
}

enum EvidenceType {
  IMAGE
  VIDEO
}

model ReturnRequest {
  id               String                @id @default(uuid())
  orderId          String                @unique
  order            Order                 @relation(fields: [orderId], references: [id])
  buyerId          String
  buyer            UserProfile           @relation(fields: [buyerId], references: [id])
  status           ReturnRequestStatus   @default(RETURN_REQUESTED)
  reason           ReturnReason
  comment          String?
  refundMethod     RefundMethod          @default(ORIGINAL_PAYMENT)
  refundAmount     Int                   // paise
  pickupCourier    String?
  pickupTrackingId String?
  pickupDate       DateTime?
  inspectionNotes  String?
  inspectionResult InspectionResult      @default(PENDING)
  restockDecision  Boolean?
  policyEligibleUntil DateTime
  policyVersion    String
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  items            ReturnItem[]
  evidence         ReturnEvidence[]
  statusHistory    ReturnStatusHistory[]
  refund           Refund?

  @@map("return_request")
}

model ReturnItem {
  id              String        @id @default(uuid())
  returnRequestId String
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderItemId     String
  orderItem       OrderItem     @relation(fields: [orderItemId], references: [id])
  quantity        Int

  @@map("return_item")
}

model ReturnEvidence {
  id               String        @id @default(uuid())
  returnRequestId  String
  returnRequest    ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  url              String
  type             EvidenceType
  cloudinaryPublicId String?
  thumbnailUrl     String?
  mimeType         String?
  fileSize         Int?
  uploadedAt       DateTime      @default(now())

  @@map("return_evidence")
}

model ReturnStatusHistory {
  id              String              @id @default(uuid())
  returnRequestId String
  returnRequest   ReturnRequest       @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  previousStatus  ReturnRequestStatus
  newStatus       ReturnRequestStatus
  actorId         String
  actorRole       String
  comment         String?
  createdAt       DateTime            @default(now())

  @@map("return_status_history")
}

model Refund {
  id               String        @id @default(uuid())
  returnRequestId  String        @unique
  returnRequest    ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  razorpayRefundId String?       @unique
  razorpayPaymentId String
  amount           Int           // paise
  status           String        // "initiated" | "processed" | "failed"
  reason           String
  initiatedAt      DateTime      @default(now())
  processedAt      DateTime?
  failedAt         DateTime?
  webhookReceivedAt DateTime?
  failureReason    String?
  createdBy        String
  updatedAt        DateTime      @updatedAt

  @@map("refund")
}



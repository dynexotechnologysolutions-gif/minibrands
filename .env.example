# Application Environment
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://minibrands.example.com

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/minibrands
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT=30000
DB_STATEMENT_TIMEOUT=30000

# Redis
REDIS_URL=redis://:password@localhost:6379/0
REDIS_TOKEN=your_upstash_token_here

# Payment Processing - Razorpay
RAZORPAY_KEY_ID=rzp_live_your_key_here
RAZORPAY_KEY_SECRET=your_secret_key_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# KYC & Verification - Signzy
SIGNZY_API_KEY=your_signzy_api_key
SIGNZY_BASE_URL=https://api.signzy.tech/api/v2
SIGNZY_WEBHOOK_SECRET=your_signzy_webhook_secret

# Email Service - Resend
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@minibrands.example.com

# AI Services (Optional)
GROQ_API_KEY=gsk_your_groq_key_here
CLAUDE_API_KEY=sk_your_claude_key
ANTHROPIC_API_KEY=sk_your_anthropic_key
AI_MODEL_NAME=meta-llama/llama-3-70b-instruct

# Error Tracking - Sentry
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your-org
SENTRY_PROJECT=velvet-lane-web
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=1.0.0

# Image Hosting - Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# Analytics - PostHog
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Business Configuration
COMMISSION_RATE_PERCENT=8
SELLER_VERIFICATION_KYC_ENABLED=true
SELLER_VERIFICATION_BANK_ENABLED=true
ESCROW_RELEASE_DAYS=3

# Logging
LOG_LEVEL=info
STRUCTURED_LOGS_ENABLED=true

# Security
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
SESSION_TIMEOUT_MINUTES=1440
ENABLE_RATE_LIMITING=true
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX_REQUESTS=100

# Infrastructure
ENABLE_HEALTH_CHECKS=true
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_STRUCTURED_LOGGING=true

# Monitoring
HEALTH_CHECK_INTERVAL_MS=30000
READINESS_CHECK_INTERVAL_MS=10000
LIVENESS_CHECK_INTERVAL_MS=30000

# Feature Flags
ENABLE_KYC_VERIFICATION=true
ENABLE_BANK_VERIFICATION=true
ENABLE_PAYMENT_PROCESSING=true
ENABLE_SELLER_ONBOARDING=true

# Deployment
DEPLOYMENT_ENVIRONMENT=production
DEPLOYMENT_REGION=us-east-1
DEPLOYMENT_VERSION=1.0.0

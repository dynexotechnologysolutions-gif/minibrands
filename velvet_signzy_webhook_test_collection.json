    {
      "name": "KYC Status - Invalid Signature Test",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "x-signzy-signature",
            "value": "incorrect_or_forged_signature_token",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"referenceId\": \"signzy_ref_mock_id_123\",\n  \"status\": \"completed\",\n  \"faceMatchScore\": 85\n}"
